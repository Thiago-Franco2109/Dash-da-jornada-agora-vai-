# Google Sheets IDs (KEEP PRIVATE, DO NOT PREFIX WITH VITE_)
GOOGLE_SHEET_ID_MAIN=your_main_sheet_id_here
GOOGLE_SHEET_ID_ACCESS=your_access_sheet_id_here
GOOGLE_SHEET_ID_LOGO=your_logo_sheet_id_here

# Global Config
VITE_API_ORIGIN=https://bigou-sheets-api.netlify.app
VITE_GOOGLE_SHEET_ID=your_fallback_sheet_id_here

# Google Auth (Required for scripts/syncSheets.js)
GOOGLE_CLIENT_EMAIL=your_email@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nYOUR_PRIVATE_KEY_HERE\\n-----END PRIVATE KEY-----\\n"

# Optional
LOGOS_SHEET_CSV_URL=
